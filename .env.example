# NVD API key — request at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Comma-separated keyword searches for AI/ML library CVEs
NVD_KEYWORDS=pytorch,tensorflow,langchain,huggingface

# AI Incident Database GraphQL endpoint
AIID_GRAPHQL_URL=https://incidentdatabase.ai/api/graphql

# PostgreSQL connection (matches docker-compose defaults)
# If another Postgres already uses 5432, set POSTGRES_PORT=5433 and match DATABASE_URL.
POSTGRES_PORT=5433
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5433/sentinel

# AIAAIC Google Sheets CSV export URL
AIAAIC_CSV_URL=https://docs.google.com/spreadsheets/d/1Bn55B4xz21-_Rgdr8BBb2lt0n_4rzLGxFADMlVW0PYI/export?format=csv&gid=888071280

# Streamlit Cloud: public App Runner base URL (no trailing slash)
# SENTINEL_API_URL=https://your-service.us-east-2.awsapprunner.com
